# Copy to docker/.env and adjust before first run:
#   cp docker/.env.example docker/.env

# Local Docker — safe defaults for http://127.0.0.1:8000
SECRET_KEY=change-me-to-a-long-random-secret

DEBUG=True
USE_HTTPS=False
ALLOWED_HOSTS=cargopulse.mx,www.cargopulse.mx,127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,https://cargopulse.mx,https://www.cargopulse.mx

# Postgres (used by docker-compose db service)
POSTGRES_DB=cargopulse
POSTGRES_USER=cargopulse
POSTGRES_PASSWORD=change-me-strong-db-password

# Google Maps — Places Autocomplete for address fields (optional locally)
# Enable "Maps JavaScript API", "Places API", and "Places API (New)" in GCP.
GOOGLE_MAPS_API_KEY=

# Host port exposed by the web container
WEB_PORT=8000
